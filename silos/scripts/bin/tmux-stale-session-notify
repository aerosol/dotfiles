#!/bin/bash
# Automatically kill tmux sessions running zsh that don't have a corresponding foot terminal window

declare -i killed=0

# Get list of foot terminal titles from niri windows
# Try different JSON structures that niri might use
foot_titles=$(niri msg -j windows 2>/dev/null | jq -r '
  if type == "array" then
    .[] | select(.app_id == "foot" or .app_id == "footclient" or .app_id == "org.codeberg.dnkl.foot") | .title // .name // empty
  elif type == "object" then
    .windows[]? | select(.app_id == "foot" or .app_id == "footclient" or .app_id == "org.codeberg.dnkl.foot") | .title // .name // empty
  else
    empty
  end
' 2>/dev/null)

# Get all tmux sessions
tmux list-sessions -F '#S' 2>/dev/null | while read session; do
  # Get the command running in the first window/pane of the session
  running_cmd=$(tmux list-panes -t "$session:0" -F '#{pane_current_command}' 2>/dev/null | head -n 1)
  
  # Only process sessions running zsh
  if [ "$running_cmd" != "zsh" ]; then
    continue
  fi
  
  # Check if this session has a corresponding foot terminal window
  # Foot terminal titles typically contain the session name or show "tmux: session_name"
  session_has_window=0
  while IFS= read -r title; do
    if echo "$title" | grep -q "$session"; then
      session_has_window=1
      break
    fi
  done <<< "$foot_titles"
  
  # Kill the session if it doesn't have a window
  if [ $session_has_window -eq 0 ]; then
    tmux kill-session -t "$session" 2>/dev/null
    if [ $? -eq 0 ]; then
      killed+=1
    fi
  fi
done

# Output session count (for status bar or logging)
count=$(tmux list-sessions 2>/dev/null | wc -l)
if [ $killed -gt 0 ]; then
  echo "$((count - killed))"
else
  echo "$count"
fi
