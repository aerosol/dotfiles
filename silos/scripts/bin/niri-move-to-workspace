#!/bin/bash

function get_name() {
	echo "" | tofi --prompt "move to workspace: "
}

function workspace_exists() {
	local name="$1"
	niri msg -j workspaces | jq -e ".[] | select(.name == \"$name\")" > /dev/null 2>&1
}

function get_unnamed_workspace_idx() {
	# Find first unnamed workspace, or return next available index
	local unnamed_idx
	unnamed_idx=$(niri msg -j workspaces | jq -r '.[] | select(.name == null) | .idx' | head -1)
	
	if [ -n "$unnamed_idx" ]; then
		echo "$unnamed_idx"
	else
		# No unnamed workspace, get highest index and add 1
		local max_idx
		max_idx=$(niri msg -j workspaces | jq -r '.[].idx' | sort -n | tail -1)
		echo $((max_idx + 1))
	fi
}

function main() {
	local workspace_name
	workspace_name=$(get_name)
	
	# Exit if no name provided
	if [ -z "$workspace_name" ]; then
		exit 0
	fi
	
	if workspace_exists "$workspace_name"; then
		# Workspace exists, just move window to it
		niri msg action move-window-to-workspace "$workspace_name"
	else
		# Workspace doesn't exist, create it first
		# Switch to an unnamed workspace (or create new one)
		local target_idx
		target_idx=$(get_unnamed_workspace_idx)
		niri msg action focus-workspace "$target_idx"
		# Rename it
		niri msg action set-workspace-name "$workspace_name"
		# Go back to original workspace and move the window
		niri msg action focus-workspace-previous
		niri msg action move-window-to-workspace "$workspace_name"
	fi
}

main
