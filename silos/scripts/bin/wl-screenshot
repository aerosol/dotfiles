#!/usr/bin/env bash

# Generate date-time string
DATE_TIME=$(date '+%Y-%m-%d_%H-%M-%S')
# Pick a random word
RANDOM_WORD=$(shuf -n 1 ~/.zsh/_short-words.txt)
# Set screenshot path
SCREENSHOT_DIR="$HOME/Pictures/Screenshots"
mkdir -p "$SCREENSHOT_DIR"
FILENAME="${DATE_TIME}_${RANDOM_WORD}.png"
FILEPATH="$SCREENSHOT_DIR/$FILENAME"

# Take screenshot, open in swappy, and save a copy
grim -g "$(slurp)" - | tee >(swappy -f -) > "$FILEPATH"
