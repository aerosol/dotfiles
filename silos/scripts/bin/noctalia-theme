#!/bin/bash
# DARK_MODE=$(jq -r '.colorSchemes.darkMode' ~/.config/noctalia/settings.json)

if [ "$1" = "true" ]; then
  gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
	INIT=1
else
	gsettings set org.gnome.desktop.interface color-scheme 'prefer-light'
	INIT=2
fi

cat > ~/.config/foot/theme.ini <<EOF
initial-color-theme=$INIT
EOF

pkill -USR${INIT} foot
