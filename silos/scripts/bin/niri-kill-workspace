#!/bin/bash

function get_current_workspace_name() {
	niri msg -j workspaces | jq -r '.[] | select(.is_focused == true) | .name'
}

function confirm_kill() {
	local workspace_name="$1"
	printf "yes\nno" | tofi --prompt "kill workspace '$workspace_name'? "
}

function get_workspace_id() {
	local name="$1"
	niri msg -j workspaces | jq -r ".[] | select(.name == \"$name\") | .id"
}

function get_windows_in_workspace() {
	local workspace_id="$1"
	niri msg -j windows | jq -r ".[] | select(.workspace_id == $workspace_id) | .id"
}

function get_tmux_sessions_in_workspace() {
	local workspace_id="$1"
	# foot/footclient windows running tmux have titles like "session:index:name ..."
	niri msg -j windows | jq -r "
		.[] |
		select(.workspace_id == $workspace_id) |
		select(.app_id == \"foot\" or .app_id == \"footclient\") |
		.title |
		capture(\"^(?<session>[^:]+):[0-9]+:\") |
		.session
	"
}

function kill_tmux_sessions_in_workspace() {
	local workspace_id="$1"
	local sessions
	sessions=$(get_tmux_sessions_in_workspace "$workspace_id" | sort -u)
	for session in $sessions; do
		if tmux has-session -t "$session" 2>/dev/null; then
			tmux kill-session -t "$session"
		fi
	done
}

function main() {
	local workspace_name
	workspace_name=$(get_current_workspace_name)
	
	# Exit if current workspace has no name
	if [ -z "$workspace_name" ] || [ "$workspace_name" = "null" ]; then
		echo "Current workspace has no name"
		exit 1
	fi
	
	# Ask for confirmation
	local confirmation
	confirmation=$(confirm_kill "$workspace_name")
	
	if [ "$confirmation" != "yes" ]; then
		exit 0
	fi
	
	local workspace_id
	workspace_id=$(get_workspace_id "$workspace_name")
	
	if [ -z "$workspace_id" ]; then
		echo "Workspace not found: $workspace_name"
		exit 1
	fi
	
	# Switch to previous workspace before killing
	niri msg action focus-workspace-previous
	
	# Kill any tmux sessions running in foot windows in this workspace
	kill_tmux_sessions_in_workspace "$workspace_id"

	# Get all windows in the workspace
	local window_ids
	window_ids=$(get_windows_in_workspace "$workspace_id")
	
	# Close each window
	for window_id in $window_ids; do
		niri msg action close-window --id "$window_id"
	done
	
	# After closing all windows, unset the workspace name
	niri msg action focus-workspace "$workspace_name"
	niri msg action unset-workspace-name
	# Switch back to previous workspace
	niri msg action focus-workspace-previous
}

main
